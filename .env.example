# Sistema Sindicato Rural - Environment Variables
# Copie este arquivo para .env e ajuste os valores conforme o ambiente

# =============================================================================
# DESENVOLVIMENTO LOCAL (Docker Compose)
# =============================================================================

# JWT Configuration (OBRIGATÓRIO em produção)
# Gere uma chave segura com: openssl rand -base64 64
JWT_SECRET=minha-chave-secreta-super-segura-para-producao-alterar-isso

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sindicato_rural
DB_USERNAME=sindicato_user
DB_PASSWORD=sindicato_pass

# File Upload Configuration
FILE_UPLOAD_DIR=/app/uploads

# Spring Profile (dev, prod, test)
SPRING_PROFILES_ACTIVE=prod

# =============================================================================
# RAILWAY DEPLOYMENT
# =============================================================================
# Use estas variáveis no painel do Railway (Variables)
#
# SPRING_PROFILES_ACTIVE=prod
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_NAME=${{Postgres.PGDATABASE}}
# DB_USERNAME=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}
# JWT_SECRET=<gere com: openssl rand -base64 32>
# FILE_UPLOAD_DIR=/app/uploads
# PORT=8080
#
# Para frontend em domínio diferente, adicione:
# CORS_ALLOWED_ORIGINS=https://seu-frontend.vercel.app,https://seu-frontend.netlify.app
#
# =============================================================================
